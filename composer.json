{
  "name": "kipdevtech/icms-back",
  "description": "ICMS backend WordPress plugin",
  "type": "wordpress-plugin",
  "license": "proprietary",
  "require": {
    "php": ">=8.1",
    "firebase/php-jwt": "^6.10",
    "webonyx/graphql-php": "^15.0"
  },
  "autoload": {
    "psr-4": {
      "ICMS\\Domain\\": "src/Domain/",
      "ICMS\\Application\\": "src/Application/",
      "ICMS\\Infrastructure\\": "src/Infrastructure/",
      "ICMS\\Presentation\\": "src/Presentation/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.11",
    "squizlabs/php_codesniffer": "^3.9"
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse src --level=9",
    "lint": "phpcs --standard=PSR12 src/"
  }
}
