{
  "name": "kipdevtech/icms-back",
  "description": "ICMS backend WordPress plugin",
  "type": "wordpress-plugin",
  "license": "proprietary",
  "require": {
    "php": ">=8.1"
  },
  "autoload": {
    "psr-4": {
      "ICMS\\Domain\\": "src/Domain/",
      "ICMS\\Application\\": "src/Application/",
      "ICMS\\Infrastructure\\": "src/Infrastructure/",
      "ICMS\\Presentation\\": "src/Presentation/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  }
}
